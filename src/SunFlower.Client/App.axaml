<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:view="clr-namespace:SunFlower.Client.View"
             xmlns:client="clr-namespace:SunFlower.Client"
             x:DataType="{x:Type client:App}"
             x:Class="SunFlower.Client.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="/Drawing/CloudsBrush.axaml" />
            </ResourceDictionary.MergedDictionaries>
            <view:ViewLocator x:Key="ViewLocator" />
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <!-- Markdown render styles -->
        <StyleInclude Source="avares://AvaloniaHex/Themes/Fluent/AvaloniaHex.axaml"/>
        <StyleInclude Source="avares://AvaloniaEdit/Themes/Fluent/AvaloniaEdit.xaml" />
        <StyleInclude Source="/Drawing/MarkdownRenderStyles.axaml" />
        <FluentTheme/>
        <StyleInclude Source="avares://HandyControl/Themes/Theme.axaml" />
    </Application.Styles>
</Application>