<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:SunFlower.Client.ViewModel"
             mc:Ignorable="d" 
             d:DesignWidth="800" 
             d:DesignHeight="450"
             x:Class="SunFlower.Client.View.SettingsView"
             x:DataType="{x:Type vm:SettingsViewModel}">
    <StackPanel>
        <!-- App -->
        <TextBlock
            Margin="20, 5"
            Text="Application"
            TextWrapping="Wrap"/>
        <Border
            Margin="20,5"
            Padding="10"
            CornerRadius="5"
            Background="{StaticResource BorderBrush}">
            <Grid
                ColumnDefinitions="90, 160">
                <TextBlock
                    Grid.Column="0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Text="Theme variant"/>
                <ComboBox
                    Grid.Column="1"
                    Name="ThemeBox"
                    Width="150"
                    SelectedIndex="{Binding Settings.Theme, Mode=TwoWay}">
                    <Interaction.Behaviors>
                        <EventTriggerBehavior EventName="SelectionChanged">
                            <InvokeCommandAction 
                                CommandParameter="{CompiledBinding ElementName=ThemeBox, Path=SelectedIndex}"
                                Command="{CompiledBinding ChangeThemeCommand}" />
                        </EventTriggerBehavior>
                    </Interaction.Behaviors>
                    <ComboBoxItem
                        Content="System"/>
                    <ComboBoxItem
                        Content="Light"/>
                    <ComboBoxItem
                        Content="Dark"/>
                </ComboBox>
            </Grid>
        </Border>
        
        <TextBlock
            Margin="20, 5"
            Text="Hex editor"
            TextWrapping="Wrap">
        </TextBlock>
        <Border
            Margin="20,5"
            Padding="10"
            CornerRadius="5"
            Background="{StaticResource BorderBrush}">
            <Grid
                ColumnDefinitions="90, 160, Auto">
                <TextBlock
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Text="Font params"/>
                <AutoCompleteBox
                    Grid.Column="1"
                    ItemsSource="{CompiledBinding InstalledFonts}"
                    Text="{CompiledBinding Settings.HexControl.Family, FallbackValue='Family', Mode=TwoWay}"
                    Width="150"/>
                <TextBox
                    Grid.Column="2"
                    Text="{CompiledBinding Settings.HexControl.Size, FallbackValue='Size', Mode=TwoWay}"
                    Width="50"/>
            </Grid>
        </Border>
        <TextBlock
            Margin="20, 5"
            Text="Text editor"
            TextWrapping="Wrap">
        </TextBlock>
        <Border
            Margin="20,5"
            Padding="10"
            CornerRadius="5"
            Background="{StaticResource BorderBrush}">
            <StackPanel
                Spacing="10">
                <Grid
                    HorizontalAlignment="Left"
                    ColumnDefinitions="90, 160, Auto">
                    <TextBlock
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        Text="Font params"/>
                    <AutoCompleteBox
                        Grid.Column="1"
                        Text="{CompiledBinding Settings.TextControl.Family, FallbackValue='Family', Mode=TwoWay}"
                        Width="150"
                        ItemsSource="{CompiledBinding InstalledFonts}"/>
                    <TextBox
                        Grid.Column="2"
                        Text="{CompiledBinding Settings.TextControl.Size, FallbackValue='Size', Mode=TwoWay}"
                        Width="50"/>
                </Grid>
                <Grid
                    HorizontalAlignment="Left"
                    ColumnDefinitions="90, 160">
                    <TextBlock
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        Text="Theme variant"/>
                    <ComboBox
                        Grid.Column="1"
                        Width="150"
                        x:Name="EditorBox"
                        SelectedIndex="{CompiledBinding Settings.TextControlTheme}"
                        ItemsSource="{CompiledBinding TextEditorThemes}">
                        <Interaction.Behaviors>
                            <EventTrigger
                                EventName="SelectionChanged">
                                <InvokeCommandAction
                                    Command="{CompiledBinding ChangeEditorThemeCommand}"
                                    CommandParameter="{CompiledBinding ElementName=EditorBox, Path=SelectedIndex}"/>
                            </EventTrigger>
                        </Interaction.Behaviors>
                    </ComboBox>
                </Grid>
            </StackPanel>
        </Border>
        <Border
            Margin="20,5"
            Padding="10"
            CornerRadius="5"
            Background="{StaticResource BorderBrush}">
            <WrapPanel>
                <Button
                    Command="{CompiledBinding DeleteFirstCacheCommand}"
                    Content="Clear 1'st Cache"
                    HotKey="Delete">
                    <Button.ContextFlyout>
                        <Flyout>
                            <TextBlock Text="Delete unsaved workspace temp files"/>
                        </Flyout>
                    </Button.ContextFlyout>
                </Button>
                <Button
                    Command="{CompiledBinding DeleteSecondCacheCommand}"
                    Content="Clear 2'nd Cache"
                    HotKey="Shift+Delete">
                    <Button.ContextFlyout>
                        <Flyout>
                            <TextBlock Text="Delete project temp files"/>
                        </Flyout>
                    </Button.ContextFlyout>
                </Button>
                <Button
                    HotKey="Ctrl+S"
                    Command="{CompiledBinding SaveCommand}"
                    Margin="20,10"
                    Width="100"
                    HorizontalAlignment="Right"
                    Content="Save">
                    <Button.ContextFlyout>
                        <Flyout>
                            <TextBlock Text="Write changes to settings file. No restart"/>
                        </Flyout>
                    </Button.ContextFlyout>
                </Button>
            </WrapPanel>
        </Border>
    </StackPanel>
</UserControl>
