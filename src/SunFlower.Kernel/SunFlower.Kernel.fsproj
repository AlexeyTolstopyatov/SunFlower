<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net8.0</TargetFramework>
        <GenerateDocumentationFile>true</GenerateDocumentationFile>
        <Version>5.0.0</Version>
        <AssemblyVersion>5.0.0</AssemblyVersion>
        <FileVersion>5.0.0</FileVersion>
    </PropertyGroup>

    <ItemGroup>
        <Compile Include="ReDefinitions.fs"/>
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\SunFlower.Abstractions\SunFlower.Abstractions.fsproj"/>
    </ItemGroup>

    <ItemGroup>
        <Compile Include="Writers\FlowerMarkdownWriter.fs"/>
        <Compile Include="Services\FlowerSeedData.fs" />
        <Compile Include="Services\FluentFlowerManager.fs"/>
        <Compile Include="Services\FlowerCompatibility.fs" />
        <Compile Include="Services\FlowerManager.fs"/>
        <Compile Include="Readers\FlowerBinarySeeker.fs"/>
    </ItemGroup>
</Project>
