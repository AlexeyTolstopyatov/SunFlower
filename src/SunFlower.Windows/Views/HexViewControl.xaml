<UserControl x:Class="SunFlower.Windows.Views.HexViewControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:SunFlower.Windows.ViewModels"
             xmlns:wpf="clr-namespace:HexView.Wpf;assembly=HexView.Wpf"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="300">
    <UserControl.DataContext>
        <local:HexViewModel/>
    </UserControl.DataContext>
    <wpf:HexViewer
        ShowAddress="True"
        FontSize="16"
        Background="{StaticResource BorderBrush}"
        Foreground="{StaticResource PrimaryTextBrush}"
        DataSource="{Binding Reader.Reader}"/>
</UserControl>
