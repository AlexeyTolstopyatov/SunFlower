<hc:Window x:Class="SunFlower.Windows.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SunFlower.Windows.ViewModels"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        mc:Ignorable="d"
        Title="Home"
        Background="{DynamicResource RegionBrush}"
        Height="780"
        Width="1200">
    <hc:Window.DataContext>
        <local:MainWindowViewModel/>
    </hc:Window.DataContext>
    <hc:Window.NonClientAreaContent>
        <Menu
            HorizontalAlignment="Center">
            <MenuItem
                HorizontalAlignment="Right"
                HorizontalContentAlignment="Right"
                Header="File">
                <MenuItem
                    Command="{Binding GetFileCommand}"
                    Header="Open">
                </MenuItem>
            </MenuItem>
            <!--Independent tools/windows-->
            <MenuItem
                Header="Application">
                <MenuItem
                    Command="{Binding ClearCacheCommand}"
                    Header="Clear Editor Cache"/>
                <MenuItem
                    Header="Clear Recent files"
                    Command="{Binding GetDeleteRecentFilesCommandCommand}"/>
                <MenuItem
                    Header="About"
                    Command="{Binding GetAboutCommand}"/>
            </MenuItem>
            <MenuItem
                Header="Tools">
                <MenuItem
                    Header="Converter"
                    Command="{Binding GetConverterWindowCommand}"/>
                <MenuItem
                    Command="{Binding GetYourTableCommand}"
                    Header="Custom Table"/>
                <MenuItem
                    CommandParameter="recent"
                    Command="{Binding GetRegistryFileCommand}"
                    Header="Edit Recent files"/>
                <MenuItem
                    Header="Edit Custom Table"
                    CommandParameter="sizes"
                    Command="{Binding GetRegistryFileCommand}"/>
            </MenuItem>
        </Menu>
    </hc:Window.NonClientAreaContent>
    <DockPanel>
        <StackPanel
            DockPanel.Dock="Left">
            <!--About-->
            <Grid
                Margin="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="50"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Image
                    Source="/Assets/sunflower256.png"/>
                <TextBlock
                    Margin="5"
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Foreground="{DynamicResource PrimaryTextBrush}">
                    <Run Text="Sunflower (Windows)"/>
                    <LineBreak/>
                    <Run Text="{Binding ClientVersion}"/>
                </TextBlock>
            </Grid>
            <hc:SideMenu
                ExpandMode="Accordion"
                Width="200"
                DockPanel.Dock="Left">
                <hc:SideMenuItem
                    Command="{Binding GetFileCommand}"
                    Header="Open">
                    <hc:SideMenuItem.Icon>
                        <Image
                            Width="30"
                            Source="/Assets/open48.png"/>
                    </hc:SideMenuItem.Icon>
                </hc:SideMenuItem>
            
                <!--Independent tools/windows-->
                <hc:SideMenuItem
                    Command="{Binding ClearCacheCommand}"
                    Header="Clear Editor Cache">
                    <hc:SideMenuItem.Icon>
                        <Image
                            Width="30"
                            Source="/Assets/delete48.png"/>
                    </hc:SideMenuItem.Icon>
                </hc:SideMenuItem>
                <hc:SideMenuItem
                    Header="Clear Recent files"
                    Command="{Binding GetDeleteRecentFilesCommandCommand}">
                    <hc:SideMenuItem.Icon>
                        <Image
                            Width="30"
                            Source="/Assets/clear48.png"/>
                    </hc:SideMenuItem.Icon>
                </hc:SideMenuItem>
                <hc:SideMenuItem
                    CommandParameter="recent"
                    Command="{Binding GetRegistryFileCommand}"
                    Header="Edit Recent files">
                    <hc:SideMenuItem.Icon>
                        <Image
                            Width="30"
                            Source="/Assets/fedit48.png"/>
                    </hc:SideMenuItem.Icon>
                </hc:SideMenuItem>

                <hc:SideMenuItem
                    Header="Converter"
                    Command="{Binding GetConverterWindowCommand}">
                    <hc:SideMenuItem.Icon>
                        <Image
                            Width="30"
                            Source="/Assets/convert48.png"/>
                    </hc:SideMenuItem.Icon>
                </hc:SideMenuItem>
                <hc:SideMenuItem
                    Command="{Binding GetYourTableCommand}"
                    Header="Your Table">
                    <hc:SideMenuItem.Icon>
                        <Image
                            Source="/Assets/paper48.png"
                            Width="30"/>
                    </hc:SideMenuItem.Icon>
                </hc:SideMenuItem>
                <hc:SideMenuItem
                    Header="Edit Your Table"
                    CommandParameter="sizes"
                    Command="{Binding GetRegistryFileCommand}">
                    <hc:SideMenuItem.Icon>
                        <Image
                            Width="30"
                            Source="/Assets/edit48.png"/>
                    </hc:SideMenuItem.Icon>
                </hc:SideMenuItem>
            </hc:SideMenu>
        </StackPanel>
        <!--             <ToggleButton -->
        <!--                 Margin="5" -->
        <!--                 Width="190" -->
        <!--                 ToolTip="Show side-panel with plugin tracing" -->
        <!--                 Content="Plugins tracing" -->
        <!--                 Style="{StaticResource ToggleButtonSwitch}" -->
        <!--                 IsChecked="{Binding IsOpen,ElementName=DrawerBottom}"/> -->

        <DataGrid
            BorderBrush="Transparent"
            Background="{StaticResource CloudDrawingBrush}"
            IsReadOnly="True"
            x:Name="RecentDataGrid"
            d:ItemsSource="{d:SampleData 10}"
            ItemsSource="{Binding RecentTable}">
            <i:Interaction.Triggers>
                <i:EventTrigger EventName="MouseDoubleClick">
                    <i:InvokeCommandAction
                        CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                        Command="{Binding GetRecentFileCommand}"/>
                </i:EventTrigger>
                <i:KeyTrigger
                    Modifiers="Shift"
                    Key="Delete">
                    <i:InvokeCommandAction
                        CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                        Command="{Binding ClearRecentFileCommand}"/>
                </i:KeyTrigger>
                <i:KeyTrigger
                    Key="Space"
                    Modifiers="Shift">
                    <i:InvokeCommandAction
                        CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                        Command="{Binding GetRecentFileCommand}"/>
                </i:KeyTrigger>
            </i:Interaction.Triggers>
        </DataGrid>
    </DockPanel>
</hc:Window>
