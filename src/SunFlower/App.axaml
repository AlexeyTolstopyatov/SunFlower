<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="SunFlower.App"
             RequestedThemeVariant="Default">
    <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <!-- XAML bindings -->
    <Application.Styles>
        <StyleInclude Source="avares://HandyControl/Themes/Theme.axaml" />
        <StyleInclude Source="avares://AvaMark/Styles/Fluent.axaml" />

        <!-- <StyleInclude Source="avares://AvaloniaEdit/Themes/Simple/AvaloniaEdit.xaml"/> -->
    </Application.Styles>
    <!-- Sunflower resources -->
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="/Drawing/CloudsBrush.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>