<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net8.0</TargetFramework>
        <GenerateDocumentationFile>true</GenerateDocumentationFile>
        <Version>4.5.0</Version>
        <AssemblyVersion>4.5.0</AssemblyVersion>
        <FileVersion>4.5.0</FileVersion>
        <Description>Sunflower kernel dynamic library</Description>
        <Copyright>CoffeeLake 2024-*</Copyright>
    </PropertyGroup>

    <ItemGroup>
        <Compile Include="ReDefinitions.fs" />
    </ItemGroup>

    <ItemGroup>
      <ProjectReference Include="..\SunFlower.Abstractions\SunFlower.Abstractions.fsproj" />
    </ItemGroup>

    <ItemGroup>
      <Compile Include="Services\IFlowerSeedManager.fs" />
      <Compile Include="Services\FlowerSeedManager.fs" />
      <Compile Include="Services\FlowerCompatibility.fs" />
    </ItemGroup>

    <ItemGroup>
      <Compile Include="Readers\FlowerBinarySeeker.fs" />
    </ItemGroup>

    <ItemGroup>
      <Compile Include="Writers\FlowerMarkdownWriter.fs" />
    </ItemGroup>

</Project>
